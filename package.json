{
  "name": "geoshot",
  "version": "0.1.0",
  "description": "GPX/KML → image/video CLI tool",
  "type": "module",
  "bin": {
    "geoshot": "./dist/bin/geoshot.js"
  },
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsup && cp -r src/renderer/templates dist/src/renderer/",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin/geoshot.js"
  },
  "dependencies": {
    "@tmcw/togeojson": "^5.8.1",
    "@turf/bbox": "^7.2.0",
    "@turf/distance": "^7.2.0",
    "@turf/length": "^7.2.0",
    "chalk": "^5.4.1",
    "chroma-js": "^3.1.2",
    "commander": "^13.1.0",
    "jsdom": "^26.0.0",
    "ora": "^8.2.0",
    "puppeteer": "^24.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/chroma-js": "^2.4.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.9",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
